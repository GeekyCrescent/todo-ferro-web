# URL del backend (Cloud Run). Para desarrollo local puedes apuntar a
# http://localhost:8080 si corres el backend, o a la URL pública de Cloud Run.
VITE_API_URL=https://todo-backend-7sluyuniza-uc.a.run.app

# Config del cliente web de Firebase (claves públicas, seguras para el frontend)
VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
